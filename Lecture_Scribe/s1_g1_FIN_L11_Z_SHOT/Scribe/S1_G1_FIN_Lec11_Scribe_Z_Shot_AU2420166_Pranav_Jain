\section*{3. Illustrative Example: $Z = X + Y$}

Let:
\begin{itemize}[leftmargin=1.5em]
    \item $X, Y$ be continuous random variables
    \item Joint pdf: $f_{X,Y}(x,y)$
\end{itemize}

Define:
\[
Z = X + Y
\]

% -----------------------------------------------------

\subsection*{Step 1: Define Auxiliary Variable}

Let:
\[
W = Y
\]

Thus,
\[
Z = X + Y, \quad W = Y
\]

% -----------------------------------------------------

\subsection*{Step 2: Inverse Transformation}

From:
\[
W = Y \Rightarrow Y = W
\]

From:
\[
Z = X + Y \Rightarrow X = Z - W
\]

Thus:
\[
x = z - w, \quad y = w
\]

% -----------------------------------------------------

\subsection*{Step 3: Compute Jacobian}

\[
J =
\begin{vmatrix}
\dfrac{\partial x}{\partial z} & \dfrac{\partial x}{\partial w} \\
\dfrac{\partial y}{\partial z} & \dfrac{\partial y}{\partial w}
\end{vmatrix}
\]

Compute partial derivatives:
\[
\frac{\partial x}{\partial z} = 1, \quad
\frac{\partial x}{\partial w} = -1
\]
\[
\frac{\partial y}{\partial z} = 0, \quad
\frac{\partial y}{\partial w} = 1
\]

Therefore,

\[
J =
\begin{vmatrix}
1 & -1 \\
0 & 1
\end{vmatrix}
= (1)(1) - (-1)(0)
= 1
\]

% -----------------------------------------------------

\subsection*{Step 4: Joint PDF of $(Z,W)$}

\[
f_{Z,W}(z,w) = f_{X,Y}(z-w, w)\, |1|
\]

\[
f_{Z,W}(z,w) = f_{X,Y}(z-w, w)
\]

% -----------------------------------------------------

\subsection*{Step 5: Marginal PDF of $Z$}

\[
f_Z(z) =
\int_{-\infty}^{\infty}
f_{X,Y}(z-w, w)\, dw
\]

\begin{tcolorbox}
\textbf{Final Result:}
\[
f_Z(z) =
\int_{-\infty}^{\infty}
f_{X,Y}(z-w, w)\, dw
\]
\end{tcolorbox}

