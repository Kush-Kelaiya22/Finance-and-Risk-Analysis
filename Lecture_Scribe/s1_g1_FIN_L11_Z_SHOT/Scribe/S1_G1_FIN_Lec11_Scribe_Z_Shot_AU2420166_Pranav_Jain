\section*{2. Function of Two Random Variables}

\subsection*{Definition}

Let $X$ and $Y$ be random variables with joint pdf:
\[
f_{X,Y}(x,y)
\]

Define new random variables:
\[
U = g_1(X,Y), \quad V = g_2(X,Y)
\]

Then $(U,V)$ is a transformation of $(X,Y)$.

% -----------------------------------------------------

\subsection*{Objective}

Determine the joint distribution:
\[
f_{U,V}(u,v)
\]

% -----------------------------------------------------

\subsection*{Method (Joint Transformation)}

Assume:
\begin{itemize}[leftmargin=1.5em]
    \item The transformation is one-to-one
    \item The inverse transformation exists:
    \[
    x = x(u,v), \quad y = y(u,v)
    \]
\end{itemize}

Then:

\[
f_{U,V}(u,v) = f_{X,Y}(x,y)\, |J|
\]

where $J$ is the Jacobian determinant:

\[
J =
\begin{vmatrix}
\dfrac{\partial x}{\partial u} & \dfrac{\partial x}{\partial v} \\
\dfrac{\partial y}{\partial u} & \dfrac{\partial y}{\partial v}
\end{vmatrix}
\]

% -----------------------------------------------------

\subsection*{Jacobian Determinant}

\[
J =
\frac{\partial x}{\partial u}
\frac{\partial y}{\partial v}
-
\frac{\partial x}{\partial v}
\frac{\partial y}{\partial u}
\]

% -----------------------------------------------------

\subsection*{Conditions}

\begin{itemize}[leftmargin=1.5em]
    \item Transformation must be one-to-one
    \item Partial derivatives must exist
    \item Jacobian must be non-zero in the region
\end{itemize}

\vspace{10pt}
\hrule
\vspace{10pt}

