\section*{1. Transformation of Random Variables}

\subsection*{Definition}

Let $X$ be a random variable with known distribution.

If a new random variable $Y$ is defined as a function of $X$, i.e.,
\[
Y = g(X),
\]
then $Y$ is called a \textbf{transformation} of the random variable $X$.

% -----------------------------------------------------

\subsection*{Objective}

Determine the probability distribution of $Y$ given:
\begin{itemize}[leftmargin=1.5em]
    \item The distribution of $X$
    \item The transformation function $g(\cdot)$
\end{itemize}

% -----------------------------------------------------

\subsection*{Method (Continuous Case)}

Assume:
\begin{itemize}[leftmargin=1.5em]
    \item $X$ is continuous
    \item $g(\cdot)$ is one-to-one and differentiable
    \item The inverse function exists: $x = g^{-1}(y)$
\end{itemize}

Then the pdf of $Y$ is:

\[
f_Y(y) = f_X(x)\left| \frac{dx}{dy} \right|
\quad \text{where } x = g^{-1}(y)
\]

\begin{tcolorbox}
\textbf{Key Formula:}
\[
f_Y(y) = f_X(g^{-1}(y)) 
\left| \frac{d}{dy}g^{-1}(y) \right|
\]
\end{tcolorbox}

% -----------------------------------------------------

\subsection*{Conditions}

\begin{itemize}[leftmargin=1.5em]
    \item $g(\cdot)$ must be one-to-one
    \item $g(\cdot)$ must be differentiable
    \item The inverse must exist in the region of interest
\end{itemize}

