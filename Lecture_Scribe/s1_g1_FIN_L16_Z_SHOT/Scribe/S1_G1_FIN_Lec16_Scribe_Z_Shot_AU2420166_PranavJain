\section*{5. Joint Cumulative Distribution Function (CDF)}

\subsection*{5.1 Notation}

\[
X \le x,\; Y \le y \equiv \{X \le x \text{ and } Y \le y\}
\]

% -----------------------------------------------------
\subsection*{5.2 Definition}

\[
F(x,y) = P(X \le x,\; Y \le y)
\]

% =====================================================
\section*{6. Joint CDF -- Continuous Case}

\[
F(x,y) = \int_c^y \int_a^x f(u,v)\,du\,dv
\]

\subsection*{Recovering Joint PDF}

\[
f(x,y) = \frac{\partial^2}{\partial x \partial y} F(x,y)
\]

% =====================================================
\section*{7. Joint CDF -- Discrete Case}

\[
F(x,y) = \sum_{x_i \le x} \sum_{y_j \le y} p(x_i,y_j)
\]

\subsection*{Interpretation}

\begin{itemize}
    \item Sum all probabilities where:
    \begin{itemize}
        \item $x_i \le x$
        \item $y_j \le y$
    \end{itemize}
\end{itemize}

% =====================================================
\section*{8. Properties of Joint CDF}

\begin{enumerate}
    \item \textbf{Non-decreasing:}
    \[
    F(x,y) \text{ does not decrease as } x \text{ or } y \text{ increases}
    \]
    
    \item \textbf{Lower-left limit:}
    \[
    \lim_{(x,y)\to(-\infty,-\infty)} F(x,y) = 0
    \]
    
    \item \textbf{Upper-right limit:}
    \[
    \lim_{(x,y)\to(\infty,\infty)} F(x,y) = 1
    \]
\end{enumerate}

