\section*{2. Discrete Case -- Joint PMF}

\subsection*{2.1 Setup}

Let:
\[
X = \{x_1, x_2, \dots, x_n\}, \quad 
Y = \{y_1, y_2, \dots, y_m\}
\]

Then:
\[
(X,Y) \in \{(x_1,y_1), (x_1,y_2), \dots, (x_n,y_m)\}
\]

% -----------------------------------------------------
\subsection*{2.2 Definition (Joint PMF)}

\[
p(x_i, y_j) = P(X = x_i, Y = y_j)
\]

\begin{itemize}
    \item Represents probability of the \textbf{joint outcome occurring simultaneously}
\end{itemize}

% -----------------------------------------------------
\subsection*{2.3 Joint PMF Table Representation}

\[
\begin{array}{c|cccc}
X \backslash Y & y_1 & y_2 & \cdots & y_m \\
\hline
x_1 & p(x_1,y_1) & p(x_1,y_2) & \cdots & p(x_1,y_m) \\
x_2 & p(x_2,y_1) & p(x_2,y_2) & \cdots & p(x_2,y_m) \\
\vdots & \vdots & \vdots & \ddots & \vdots \\
x_n & p(x_n,y_1) & p(x_n,y_2) & \cdots & p(x_n,y_m)
\end{array}
\]

\subsubsection*{Key Properties}

\begin{enumerate}
    \item \[
    0 \le p(x_i, y_j) \le 1
    \]
    
    \item \[
    \sum_{i=1}^{n} \sum_{j=1}^{m} p(x_i, y_j) = 1
    \]
\end{enumerate}

% -----------------------------------------------------
\subsection*{2.4 Example: Rolling Two Dice}

\textbf{Experiment:} Roll two fair dice

\textbf{Define:}
\begin{itemize}
    \item $X$ : value on first die
    \item $T$ : total (sum) of both dice
\end{itemize}

\textbf{Joint Probability:}
\[
P((i,j)) = \frac{1}{36}
\]

\begin{itemize}
    \item Each outcome has equal probability
    \item Joint PMF table consists of values $0$ or $\frac{1}{36}$
    \item $X$ and $T$ are \textbf{not independent}
\end{itemize}

