\section*{4. Worked Example (Continuous Case)}

\subsection*{Given}

\[
f(x,y) = 4xy, \quad 0 \le x \le 1,\; 0 \le y \le 1
\]

\begin{itemize}
    \item Domain: $[0,1]^2$
\end{itemize}

% -----------------------------------------------------
\subsection*{Task 1: Check Validity (Normalization)}

\[
\int_0^1 \int_0^1 4xy \, dx \, dy
\]

\[
= \int_0^1 \left( \int_0^1 4xy \, dx \right) dy
\]

\[
= \int_0^1 4y \left( \int_0^1 x \, dx \right) dy
\]

\[
= \int_0^1 4y \left[ \frac{x^2}{2} \right]_0^1 dy
\]

\[
= \int_0^1 4y \cdot \frac{1}{2} \, dy
\]

\[
= \int_0^1 2y \, dy
\]

\[
= \left[ y^2 \right]_0^1 = 1
\]

\textbf{Conclusion:}
\begin{itemize}
    \item $f(x,y) \ge 0$ and total probability $=1$
    \item Hence, valid joint PDF
\end{itemize}

% -----------------------------------------------------
\subsection*{Task 2: Compute $P(A)$}

\[
A = \{X < 0.5,\; Y > 0.5\}
\]

\[
P(A) = \int_{0}^{0.5} \int_{0.5}^{1} 4xy \, dy \, dx
\]

\[
= \int_0^{0.5} \left( \int_{0.5}^{1} 4xy \, dy \right) dx
\]

\[
= \int_0^{0.5} 4x \left[ \frac{y^2}{2} \right]_{0.5}^{1} dx
\]

\[
= \int_0^{0.5} 4x \cdot \frac{1 - 0.25}{2} dx
\]

\[
= \int_0^{0.5} 4x \cdot \frac{0.75}{2} dx
\]

\[
= \int_0^{0.5} 2x(0.75) dx
\]

\[
= \int_0^{0.5} 1.5x \, dx
\]

\[
= \left[ \frac{1.5x^2}{2} \right]_0^{0.5} = \frac{3}{16}
\]

