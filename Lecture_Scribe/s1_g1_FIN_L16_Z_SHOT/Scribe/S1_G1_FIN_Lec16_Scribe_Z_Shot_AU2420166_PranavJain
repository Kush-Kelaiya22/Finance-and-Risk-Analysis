\section*{3. Continuous Case -- Joint PDF}

\subsection*{3.1 Analogy with Discrete Case}

\begin{itemize}
    \item Discrete $\rightarrow$ Continuous:
    \begin{itemize}
        \item Values $\rightarrow$ Intervals
        \item PMF $\rightarrow$ PDF
        \item Sums $\rightarrow$ Double integrals
    \end{itemize}
\end{itemize}

% -----------------------------------------------------
\subsection*{3.2 Support (Domain)}

If:
\[
X \in [a,b], \quad Y \in [c,d]
\]

Then:
\[
(X,Y) \in [a,b] \times [c,d]
\]

% -----------------------------------------------------
\subsection*{3.3 Definition (Joint PDF)}

\[
P((X,Y) \text{ in small area } dx,dy) \approx f(x,y)\,dx\,dy
\]

% -----------------------------------------------------
\subsection*{3.4 Key Properties}

\begin{enumerate}
    \item \[
    f(x,y) \ge 0
    \]
    
    \item \[
    \int_c^d \int_a^b f(x,y)\,dx\,dy = 1
    \]
\end{enumerate}

\begin{itemize}
    \item Note: $f(x,y)$ may be \textbf{greater than 1}
\end{itemize}

